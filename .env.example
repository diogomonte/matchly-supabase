# Supabase project URL and anonymous key — found in your Supabase project settings under "API"
SUPABASE_URL=https://zbxxhvipbznosqhsqzza.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>

# Service role key — used for admin operations, keep this secret and never expose it in the browser
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Google OAuth credentials — obtained from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
# Set "Authorized redirect URIs" to: https://zbxxhvipbznosqhsqzza.supabase.co/auth/v1/callback
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
