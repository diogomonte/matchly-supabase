# Production secrets for the hosted Supabase project.
# Copy this file to .env.production, fill in real values, then run:
#   make configure-auth — enables phone OTP on the hosted project
#
# .env.production is gitignored. Never commit real credentials.

# Twilio — required for phone OTP
# Account SID and Auth Token: https://console.twilio.com
# Messaging Service SID: Twilio Console > Messaging > Services
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_MESSAGE_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase Management API access token — required for make configure-auth
# Generate at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
