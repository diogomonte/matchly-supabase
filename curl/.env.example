# Copy this file to curl/.env and fill in the values from `supabase status`.
# Then run: source curl/.env

SUPABASE_URL="http://127.0.0.1:54321"
ANON_KEY="<anon key from supabase status>"
SERVICE_ROLE_KEY="<service role key from supabase status>"

# Filled in after running auth.sh sign-in steps:
USER_JWT=""
USER_ID=""

# Filled in as you create resources:
CLUB_ID=""
REQUEST_ID=""
MATCH_ID=""
